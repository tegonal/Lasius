{
  "name": "lasius-frontend",
  "private": true,
  "version": "2.0.0",
  "description": "Lasius NextJS Frontend Application Server",
  "author": "tegonal.com <info@tegonal.com>",
  "license": "AGPL 3.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "next build",
    "start": "next start",
    "start-local": "next start -p 3001",
    "dev": "next dev -p 3001",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint-fix": "eslint --cache --cache-location ./node_modules/.cache/eslint . --fix",
    "prettier": "prettier --cache --check --write 'src/**/*.{ts,tsx,js,d.ts}'",
    "check": "yarn run lint-fix && yarn run prettier && yarn run typecheck",
    "clean": "yarn cache clean --all && rm -rf ./node_modules & rm -rf ./.next & rm -rf ./.swc",
    "cleaner": "yarn run clean && rm yarn.lock && yarn install && yarn rebuild",
    "clean-prod": "yarn workspaces focus --production && yarn cache clean --all",
    "up": "yarn upgrade-interactive",
    "i18n-extract": "i18next",
    "orval": "rm -rf ./src/lib/api/lasius && orval --config ./orval.config.mjs && yarn check",
    "tsc": "tsc --noEmit --incremental --watch",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true yarn run build",
    "self-update": "yarn set version latest"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.2",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@nivo/stream": "^0.99.0",
    "@popperjs/core": "^2.11.8",
    "@vercel/og": "^0.11.1",
    "axios": "^1.13.6",
    "boring-avatars": "^2.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "es-toolkit": "^1.45.1",
    "framer-motion": "^12.38.0",
    "i18next": "^25.8.20",
    "immer": "^11.1.4",
    "js-cookie": "^3.0.5",
    "json-stable-stringify": "^1.3.0",
    "lucide-react": "^0.577.0",
    "negotiator": "^1.0.0",
    "next": "^15.5.14",
    "next-auth": "4.24.13",
    "next-i18next": "^15.4.3",
    "next-mdx-remote": "^6.0.0",
    "next-seo": "^6.8.0",
    "parse-json": "^8.3.0",
    "react": "19.2.4",
    "react-async-hook": "^4.0.0",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-i18next": "^16.5.8",
    "react-popper": "^2.3.0",
    "react-use-websocket": "^4.13.0",
    "satori": "^0.26.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tslog": "^4.10.2",
    "usehooks-ts": "^3.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^15.5.14",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@tailwindcss/postcss": "4.2.2",
    "@types/d3-shape": "^3.1.8",
    "@types/js-cookie": "^3.0.6",
    "@types/negotiator": "^0.6.4",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-license-header": "^0.9.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "i18next-parser": "^9.4.0",
    "jsonc-eslint-parser": "^3.1.0",
    "orval": "8.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svgo": "^4.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  },
  "packageManager": "yarn@4.13.0"
}
